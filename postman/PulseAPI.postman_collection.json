{
  "info": {
    "name": "PulseAPI",
    "description": "Collection para validar rapidamente os fluxos principais da PulseAPI.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": {
      "major": 1,
      "minor": 0,
      "patch": 0
    }
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 ou 400 (email já existente)', function () {",
                  "  pm.expect([201, 400]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}",
                  "if (pm.response.code === 400) {",
                  "  console.log('Register retornou 400 (possivelmente email já cadastrado). Execute Login.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.expect(json.accessToken).to.be.a('string');",
                  "pm.collectionVariables.set('accessToken', json.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Monitors",
      "item": [
        {
          "name": "Create Monitor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{monitorName}}\",\n  \"url\": \"{{monitorUrl}}\",\n  \"intervalSec\": {{intervalSec}},\n  \"timeoutMs\": {{timeoutMs}},\n  \"enabled\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/monitors",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "monitors"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('monitorId', json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "List Monitors",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/monitors",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "monitors"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const arr = pm.response.json();",
                  "if (Array.isArray(arr) && arr.length > 0 && arr[0].id) {",
                  "  pm.collectionVariables.set('monitorId', arr[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Monitor",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/monitors/{{monitorId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "monitors",
                "{{monitorId}}"
              ]
            }
          }
        },
        {
          "name": "Enable Monitor",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/monitors/{{monitorId}}/enable",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "monitors",
                "{{monitorId}}",
                "enable"
              ]
            }
          }
        },
        {
          "name": "Recheck Monitor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/monitors/{{monitorId}}/recheck",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "monitors",
                "{{monitorId}}",
                "recheck"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Metrics",
      "item": [
        {
          "name": "Monitor Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/monitors/{{monitorId}}/checks/summary?window={{window}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "monitors",
                "{{monitorId}}",
                "checks",
                "summary"
              ],
              "query": [
                {
                  "key": "window",
                  "value": "{{window}}"
                }
              ]
            }
          }
        },
        {
          "name": "Dashboard Overview",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/dashboard/overview?window={{window}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "dashboard",
                "overview"
              ],
              "query": [
                {
                  "key": "window",
                  "value": "{{window}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Incidents & Alerts",
      "item": [
        {
          "name": "List Incidents (open)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/monitors/{{monitorId}}/incidents?status=open",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "monitors",
                "{{monitorId}}",
                "incidents"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "open"
                }
              ]
            }
          }
        },
        {
          "name": "List Alerts (unacked)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/alerts?status=unacked",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "alerts"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "unacked"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const alerts = pm.response.json();",
                  "if (Array.isArray(alerts) && alerts.length > 0 && alerts[0].id) {",
                  "  pm.collectionVariables.set('alertId', alerts[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Ack Alert",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/alerts/{{alertId}}/ack",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "alerts",
                "{{alertId}}",
                "ack"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userEmail",
      "value": "candidate+pulseapi@example.com"
    },
    {
      "key": "userPassword",
      "value": "123456"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "monitorId",
      "value": ""
    },
    {
      "key": "alertId",
      "value": ""
    },
    {
      "key": "monitorName",
      "value": "PulseAPI Demo Monitor"
    },
    {
      "key": "monitorUrl",
      "value": "https://www.google.com"
    },
    {
      "key": "intervalSec",
      "value": "60"
    },
    {
      "key": "timeoutMs",
      "value": "5000"
    },
    {
      "key": "window",
      "value": "7d"
    }
  ]
}
